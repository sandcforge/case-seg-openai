# OpenAI API Key (add your real key here for testing)
# from openai sheng-customer-service-case-analysis
OPENAI_API_KEY=

# Anthropic API Key
ANTHROPIC_API_KEY=

GEMINI_API_KEY=

FIREBASE_API_KEY=
FIREBASE_EMAIL=
FIREBASE_PASSWORD=

# Google BigQuery Configuration
#   1. 打开 Google Cloud Console
#     - https://console.cloud.google.com/
#   2. 进入 IAM & Admin → Service Accounts
#     - https://console.cloud.google.com/iam-admin/serviceaccounts?project=plantstory
#   3. 找到对应的 Service Account
#     - 从你的 .env 中可以看到 email 是：
#     - sheng-customer-service-ai@plantstory.iam.gserviceaccount.com
#   项目级别权限是：
#   - roles/bigquery.dataViewer（只读）
#   - roles/bigquery.jobUser（运行作业）

#   但在 customer_service 数据集级别有 WRITER 权限，所以：
#   - ✅ 可以写入 plantstory.customer_service.support_message_cases 表
BIGQUERY_CREDENTIALS_JSON='{"type":"service_account","project_id":"plantstory","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@plantstory.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'